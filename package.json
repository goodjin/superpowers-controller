{
  "name": "superpowers-controller",
  "version": "0.1.11",
  "description": "Unofficial stateful workflow controller for the Superpowers methodology on OpenCode.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/src/index.d.ts",
  "bin": {
    "superpowers-controller": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "assets",
    "scripts/install.sh",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tui": {
      "types": "./dist/src/tui.d.ts",
      "import": "./dist/tui.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && bun build src/index.ts --outdir dist --target bun --format esm --external @opencode-ai/plugin --external @opencode-ai/plugin/tool && bun build src/tui.ts --outdir dist --target bun --format esm --external @opentui/solid && bun build src/cli/index.ts --outdir dist/cli --target bun --format esm --packages external && tsc --emitDeclarationOnly",
    "test": "bun test ./test/*.test.ts ./test/support/*.test.ts",
    "test:e2e:opencode": "bun run build && bun test ./test/support/opencode-e2e/*.test.ts ./test/e2e/*.test.ts",
    "doctor": "bun run src/cli/index.ts doctor",
    "deploy:superagent": "bash scripts/deploy-superagent-runtime.sh restart",
    "e2e:opencode": "bun run build && bun run scripts/e2e-opencode-1.16.2.ts",
    "e2e:opencode:mock-llm": "bun run build && bun run scripts/e2e-opencode-mock-llm.ts"
  },
  "keywords": [
    "opencode",
    "superpowers",
    "workflow",
    "plugin",
    "agents"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goodjin/superpowers-controller.git"
  },
  "homepage": "https://github.com/goodjin/superpowers-controller#readme",
  "bugs": {
    "url": "https://github.com/goodjin/superpowers-controller/issues"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.15.4",
    "@opentui/solid": "^0.3.2",
    "jsonc-parser": "^3.3.1",
    "solid-js": "1.9.12",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/babel__core": "7.20.5",
    "bun-types": "^1.3.10",
    "typescript": "^6.0.0-dev.20260518"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  }
}
